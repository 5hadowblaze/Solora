rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function owns(userId) { return request.auth != null && request.auth.uid == userId; }
    function validImageUpload() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 8 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|heic|heif|webp)');
    }
    function validMotionUpload() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 16 * 1024 * 1024
        && request.resource.contentType.matches('video/(mp4|quicktime)');
    }
    match /users/{userId}/wins/{winId}/photos/{fileName} {
      allow read, delete: if owns(userId);
      allow create, update: if owns(userId) && validImageUpload();
    }

    match /users/{userId}/wins/{winId}/stickers/{fileName} {
      allow read, delete: if owns(userId);
      allow create, update: if owns(userId) && validImageUpload();
    }
    match /users/{userId}/wins/{winId}/motion/{fileName} {
      allow read, delete: if owns(userId);
      allow create, update: if owns(userId) && validMotionUpload();
    }
    match /{legacyKind}/{legacyUserId}/{fileName} {
      allow read: if legacyKind in ['win-photos', 'stickers']
        && request.auth != null
        && resource.metadata.soloraOwnerUID == request.auth.uid;
      allow write: if false;
    }
  }
}
